# ─────────────────────────────────────────────────────────────────────────────
# Sechel — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

## Database (Turso / libSQL)
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=
# Optional: scopes all data to a logical tenant
TENANT_ID=default

## Auth
# Dev bypass — only active when set to a non-empty value.
# In production, leave unset and use real user tokens from the database.
SECHEL_DEV_TOKEN=

## Admin bootstrap (first admin on empty instance)
# Only used when leaving this unset would block the first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Secret for JWT session tokens. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
