---
import AdminLayout from '@/layouts/AdminLayout.astro';
import UsersList from '@/components/users/UsersList';
---

<AdminLayout title="Users" currentPath="/admin/users">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-black tracking-tighter uppercase text-on-surface">Users</h1>
        <p class="text-xs font-mono text-outline uppercase tracking-widest mt-1">
          User Management &amp; Access Control
        </p>
      </div>
    </div>
    <UsersList client:load />
  </div>
</AdminLayout>
