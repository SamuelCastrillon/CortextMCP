---
import AdminLayout from '@/layouts/AdminLayout.astro';
---

<AdminLayout title="Memories" currentPath="/admin/memories">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-black tracking-tighter uppercase text-on-surface">Memories</h1>
      <p class="text-xs font-mono text-outline uppercase tracking-widest mt-1">
        Memory Exploration &amp; Discovery
      </p>
    </div>
    <div class="border border-outline-variant bg-card p-8 text-center">
      <p class="text-sm text-muted-foreground">Memories module coming soon.</p>
    </div>
  </div>
</AdminLayout>
